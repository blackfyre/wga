{
  "name": "wga",
  "version": "1.0.0",
  "description": "Front-end build system for the Web Gallery of Art: Project Phoenix",
  "private": "true",
  "scripts": {
    "build": "bun run build:css && bun run build:js",
    "build:js": "bun build ./resources/js/app.ts --outdir ./internal/assets/public/js --target=browser --minify --sourcemap --splitting",
    "build:css": "postcss ./resources/css/style.pcss -o ./internal/assets/public/css/style.css",
    "build:watch:css": "bun run build:css --watch",
    "build:watch:js": "bun run build:js --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackfyre/wga.git"
  },
  "author": "Miklós Galicz <miklos.galicz@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blackfyre/wga/issues"
  },
  "homepage": "https://github.com/blackfyre/wga#readme",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.37",
    "animate.css": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "choices.js": "^11.1.0",
    "concurrently": "^8.2.2",
    "cssnano": "^6.1.2",
    "daisyui": "^5.5.19",
    "dotenv": "^16.6.1",
    "esbuild": "0.20.1",
    "esbuild-plugin-copy": "^2.1.1",
    "htmx.org": "2.0.4",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "tailwind": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "trix": "^2.1.16",
    "viewerjs": "^1.11.7"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.43",
    "caniuse-lite": "^1.0.30001806",
    "chart.js": "^4.5.1"
  }
}
